rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isExchangeParticipant(exchangeData) {
      return isSignedIn()
        && exchangeData != null
        && request.auth.uid in [
          exchangeData.ownerUid,
          exchangeData.targetUid,
          exchangeData.requesterUid,
        ];
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /notifications/{notificationId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create, delete: if false;
        allow update: if request.auth != null
          && request.auth.uid == userId
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['read', 'readAt'])
          && request.resource.data.read == true;
      }
    }

    match /posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.ownerUid == request.auth.uid;
    }

    match /exchanges/{exchangeId} {
      allow read: if isExchangeParticipant(resource.data);
      allow create: if isSignedIn()
        && request.resource.data.requesterUid == request.auth.uid;
      allow update: if isExchangeParticipant(resource.data)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'status',
          'updatedAt',
        ]);
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isExchangeParticipant(
          get(/databases/$(database)/documents/exchanges/$(exchangeId)).data
        );
        allow create: if isExchangeParticipant(
            get(/databases/$(database)/documents/exchanges/$(exchangeId)).data
          )
          && request.resource.data.senderUid == request.auth.uid;
        allow update, delete: if false;
      }
    }
  }
}